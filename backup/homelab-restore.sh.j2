#!/usr/bin/env bash
set -euo pipefail

PASSPHRASE_FILE="/etc/homelab/backup-passphrase"
usage() {
    echo "Usage: $0 <backup-file.tar.gz.gpg>"
    echo ""
    echo "Restores a Podman volume from an encrypted backup."
    echo "The backup filename must follow the format: <user>_<volume>_<date>.tar.gz.gpg"
    exit 1
}

if [[ $# -ne 1 ]]; then
    usage
fi

BACKUP_FILE="$1"

if [[ ! -f "$BACKUP_FILE" ]]; then
    echo "ERROR: Backup file not found: $BACKUP_FILE" >&2
    exit 1
fi

if [[ ! -f "$PASSPHRASE_FILE" ]]; then
    echo "ERROR: Passphrase file not found at $PASSPHRASE_FILE" >&2
    exit 1
fi

# Parse user and volume from filename
# Expected format: <user>_<volume>_<date>.tar.gz.gpg
filename=$(basename "$BACKUP_FILE")
if [[ ! "$filename" =~ ^([^_]+)_(.+)_[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}\.tar\.gz\.gpg$ ]]; then
    echo "ERROR: Filename does not match expected format: <user>_<volume>_<YYYY-MM-DD_HH-MM-SS>.tar.gz.gpg" >&2
    exit 1
fi

user="${BASH_REMATCH[1]}"
volume="${BASH_REMATCH[2]}"

echo "Restoring volume '$volume' for user '$user' from $filename"

# Verify user exists
if ! id "$user" &>/dev/null; then
    echo "ERROR: User '$user' does not exist" >&2
    exit 1
fi

# Verify volume exists
if ! runuser -u "$user" -- podman volume exists "$volume" 2>/dev/null; then
    echo "ERROR: Volume '$volume' does not exist for user '$user'" >&2
    exit 1
fi

# Find running containers using this volume
containers=$(runuser -u "$user" -- podman ps --filter "volume=$volume" --format '{% raw %}{{.Names}}{% endraw %}' 2>/dev/null) || true
stopped_containers=()

# Stop containers that use this volume
while IFS= read -r container; do
    [[ -z "$container" ]] && continue
    if systemctl --user -M "$user@" stop "$container.service" 2>/dev/null; then
        stopped_containers+=("$container")
        echo "Stopped container: $container"
    fi
done <<< "$containers"

# Decrypt and import
echo "Importing backup into volume '$volume'..."
if gpg --batch --decrypt --passphrase-file "$PASSPHRASE_FILE" "$BACKUP_FILE" \
    | gunzip \
    | runuser -u "$user" -- podman volume import "$volume" -; then
    echo "Successfully restored volume '$volume' for user '$user'"
else
    echo "ERROR: Failed to restore volume '$volume'" >&2
fi

# Restart stopped containers
for container in "${stopped_containers[@]}"; do
    if systemctl --user -M "$user@" start "$container.service" 2>/dev/null; then
        echo "Restarted container: $container"
    else
        echo "WARNING: Failed to restart container $container" >&2
    fi
done

echo "Restore complete"
